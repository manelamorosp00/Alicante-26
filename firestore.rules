rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global safety net — deny everything not explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // Members — anyone logged in can read; any logged-in user can update
    // (needed to link googleUid and edit nickname/avatar/role)
    match /members/{memberId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Expenses — any logged-in user can read/write/delete
    match /expenses/{expenseId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Plans / Itinerary — any logged-in user can read/write/delete
    match /plans/{planId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Votes / Polls — any logged-in user can read/write/delete
    match /votes/{voteId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Custom Wheels — any logged-in user can read/write/delete
    match /wheels/{wheelId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Drinks counter — everyone sees all counts, each member writes their own doc
    match /drinks/{memberId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Playlist del viatge
    match /playlist/{songId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
